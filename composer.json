{
    "name": "davidgut/simple-auth",
    "description": "A simple authentication package for Laravel.",
    "license": "MIT",
    "authors": [
        {
            "name": "David Gut",
            "email": "david@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DavidGut\\SimpleAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DavidGut\\SimpleAuth\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DavidGut\\SimpleAuth\\SimpleAuthServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
